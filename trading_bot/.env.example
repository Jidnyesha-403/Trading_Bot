# Copy this file to .env and fill in your Binance Futures Demo Trading credentials.
#
# As of 2026, Binance retired the old GitHub-login testnet
# (testnet.binancefuture.com) in favor of "Demo Trading" inside a regular
# Binance.com account:
#   1. Log in to binance.com with your normal account.
#   2. Open "Binance Demo Trading" (separate sandbox with fake funds).
#   3. Go to its API Key Management page and generate a demo API key/secret.

BINANCE_API_KEY=your_demo_api_key_here
BINANCE_API_SECRET=your_demo_api_secret_here

# Usually you won't need to change these:
BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com
BINANCE_REQUEST_TIMEOUT=10
BINANCE_RECV_WINDOW=5000
BOT_LOG_DIR=logs
BOT_LOG_FILE=trading_bot.log
